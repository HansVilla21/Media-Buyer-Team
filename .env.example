# ============================================================
# Media Buyer Team — Variables de Entorno
# ============================================================
# Copia este archivo como .env y llena los valores reales.
# NUNCA subas el archivo .env a Git o compartas su contenido.
# ============================================================

# --- ANTHROPIC ---
# Clave de API para los agentes Claude
# Obtén la tuya en: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# --- PERPLEXITY ---
# Clave de API para el agente INVESTIGADOR
# Obtén/regenera la tuya en: https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=pplx-...

# --- GOOGLE GEMINI ---
# Clave de API para generación de imágenes (Imagen 3) y modelos Gemini
# Regenera/obtén la tuya en: https://aistudio.google.com/app/apikey
# Casos de uso: generación de imágenes para ads/contenido, análisis visual, Gemini Pro/Flash
GEMINI_API_KEY=AIzaSy...

# --- UPLOAD POST (Publicación automática en Instagram) ---
# Clave de API para publicar carruseles directamente en Instagram
# Obtén la tuya en: https://upload-post.com/
# Usada por: scripts/noticias_ia_carousel.py y scripts/tips_carousel.py con --publicar
UPLOAD_POST_API_KEY=

# --- META ADS (Opcional - para MEDIA BUYER) ---
# Token de acceso de largo plazo de Meta Business
# Obtén el tuyo en: https://developers.facebook.com/
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=act_...
META_PIXEL_ID=

# --- CONFIGURACIÓN DEL PROYECTO ---
# Nombre de la cuenta de Instagram principal
IG_ACCOUNT=hansvilla.ai

# Directorio base del proyecto (ruta absoluta)
PROJECT_ROOT=C:/Users/hvill/Documents/Cloude Code/Media Buyer Team

# --- NOTIFICACIONES (Opcional) ---
# Para recibir alertas cuando los agentes terminen tareas largas
SLACK_WEBHOOK_URL=
DISCORD_WEBHOOK_URL=
